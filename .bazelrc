common --noenable_bzlmod

build --incompatible_enable_cc_toolchain_resolution

build --python_path=/usr/bin/python3
test --python_path=/usr/bin/python3

# Name bazel-out directories by the target platform so that the host
# and Raspberry Pi builds (which use different toolchains) coexist in
# the same output tree instead of clobbering one another.  This is the
# platform-based replacement for the old per-CPU output directories and
# the bazel#12036 workaround.
#
# REVISIT ON BAZEL UPGRADE (bazelbuild/bazel#27575): these flags are
# still experimental as of 7.4.1.  Bazel 9 turns
# --experimental_platform_in_output_dir on by default for the *exec*
# config only; the everywhere/target-config default is proposed for
# Bazel 10, so setting it explicitly here is still required until then.
# Bazel 9 also RENAMES --experimental_override_name_platform_in_output_dir
# to --experimental_override_platform_cpu_name -- rename the two lines
# below when bumping BAZEL_VERSION.
build --experimental_platform_in_output_dir
build --experimental_override_name_platform_in_output_dir=//:armeabihf=armeabihf
build --experimental_override_name_platform_in_output_dir=//:aarch64=aarch64

# Convenience configs for cross-compiling to a Raspberry Pi.
build:pi --platforms=//:armeabihf
test:pi --platforms=//:armeabihf

build:pi64 --platforms=//:aarch64
test:pi64 --platforms=//:aarch64
